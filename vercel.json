{
  "functions": {
    "server/api/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/api/index.js"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "client/.next",
  "installCommand": "npm run install:all",
  "framework": "nextjs"
}