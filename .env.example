# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── MongoDB (Optional) ────────────────────────────────────
# Enable MongoDB if you need document storage alongside Supabase.
MONGODB_ENABLE=false
MONGODB_URI=mongodb://127.0.0.1:27017/adflow
MONGODB_DB_NAME=adflow

# ── Client (Next.js public env) ───────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Vercel Deployment (Monorepo) ──────────────────────────
CRON_SECRET=long-random-string-for-vercel-cron
